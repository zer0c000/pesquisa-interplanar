{
  "buildCommand": null,
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/pesquisa", "destination": "/pesquisa.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
